@startuml
' --- Cấu hình giao diện ---
skinparam Style strictuml
skinparam SequenceMessageAlignment center
skinparam monochrome true
skinparam shadowing false

' --- Khai báo các đối tượng ---
actor "User" as User
participant "LoginPanel" as LoginPanel
participant "AuthController" as AuthController
participant "AuthService" as AuthService
participant "UserRepository" as UserRepository
database "MySQL / JPA" as Database

' --- Luồng sự kiện ---
User -> LoginPanel : Enter username and password
User -> LoginPanel : Click Login

LoginPanel -> AuthController : login(username, password)
activate AuthController

AuthController -> AuthService : authenticate(username, password)
activate AuthService

AuthService -> UserRepository : findByUsername(username)
activate UserRepository

UserRepository -> Database : SELECT * FROM users WHERE username = ?
activate Database
Database -->> UserRepository : ResultSet / User Data
deactivate Database

UserRepository -->> AuthService : User Object (or null)
deactivate UserRepository

' --- Khối điều kiện Alt ---
alt User exists AND password matches
    AuthService -> UserRepository : updateLastLogin(user)
    activate UserRepository
    UserRepository -> Database : UPDATE users SET last_login = ...
    activate Database
    Database -->> UserRepository : void
    deactivate Database
    UserRepository -->> AuthService : void
    deactivate UserRepository

    AuthService -->> AuthController : AuthenticationResult (Success)
    AuthController -->> LoginPanel : Redirect to Dashboard
    LoginPanel -->> User : Show Welcome Message

else Invalid credentials
    AuthService -->> AuthController : throw AuthenticationException
    deactivate AuthService

    AuthController -->> LoginPanel : Error message
    deactivate AuthController

    LoginPanel -->> User : Show Error Message
end

@enduml