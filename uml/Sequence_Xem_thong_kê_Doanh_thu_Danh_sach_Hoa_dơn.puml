@startuml
' --- Cấu hình giao diện ---
skinparam Style strictuml
skinparam SequenceMessageAlignment center
skinparam monochrome true
skinparam shadowing false

' --- Khai báo các đối tượng ---
actor "Quản lý\n(Admin)" as Admin
participant "ReportPanel\n(Giao diện)" as UI
participant "ReportController" as Controller
participant "ReportService" as Service
participant "OrderRepository" as Repo
database "MySQL" as DB

' --- Luồng xử lý ---
Admin -> UI : Chọn thời gian (Từ ngày - Đến ngày)\nChọn Nhân viên (staff_id / Tất cả)
Admin -> UI : Nhấn "Xem thống kê"
activate UI

UI -> Controller : getRevenueReport(startDate, endDate, staffId)
activate Controller

Controller -> Service : generateReportData(startDate, endDate, staffId)
activate Service

Service -> Repo : findOrders(startDate, endDate, staffId)
activate Repo

Repo -> DB : SELECT * FROM 'Order' WHERE order_date BETWEEN ? AND ? \nAND (staff_id = ? OR ? IS NULL)
activate DB
DB -->> Repo : Trả về tập kết quả
deactivate DB

Repo -->> Service : List<OrderEntity>
deactivate Repo

Service -->> Controller : ReportDTO (TotalRevenue, ChartData, List<OrderDTO>)
deactivate Service

Controller -->> UI : Trả về dữ liệu báo cáo (JSON)
deactivate Controller

UI -->> Admin : Hiển thị Biểu đồ, Tổng doanh thu\nDanh sách hóa đơn chi tiết
deactivate UI

@enduml